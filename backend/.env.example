# Example backend environment variables for GeminiClone
# Copy this file to `backend/.env` (don't commit secrets) or set these in your hosting provider.

# MongoDB connection
MONGODB_URI=mongodb://localhost:27017/geminiclone

# JWT secret
JWT_SECRET=your-super-secret-jwt-key

# Backend public URL (used to construct callback if GOOGLE_CALLBACK_URL not set)
# Example: https://gemini-clone-yp44.onrender.com
BACKEND_URL=

# Full Google OAuth callback URL (preferred to set explicitly)
# Example: https://gemini-clone-yp44.onrender.com/api/auth/google/callback
GOOGLE_CALLBACK_URL=

# Google OAuth client credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend deployed app URL (used to redirect after successful OAuth)
CLIENT_URL=https://gemini-girdhar.netlify.app

# Port (optional)
PORT=5000

# Node environment
NODE_ENV=development
